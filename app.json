{
  "expo": {
    "name": "SmartBrew POS",
    "slug": "SmartBrewApp",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartbrew.pos"
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "statusBar": {
        "hidden": true
      },
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.smartbrew.pos",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "experiments": {
      "baseUrl": "/SmartBrew"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-sharing",
      "expo-image-picker",
      [
        "with-rn-bluetooth-classic",
        {
          "peripheralUsageDescription": "SmartBrew POS connects to nearby Bluetooth receipt printers.",
          "alwaysUsageDescription": "SmartBrew POS uses Bluetooth to print receipts and kitchen tickets."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#15803d",
          "image": "./assets/splash-icon.png",
          "resizeMode": "cover"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/c8f75f66-476b-46eb-a12f-773a1f349458",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "c8f75f66-476b-46eb-a12f-773a1f349458"
      }
    },
    "owner": "chonchonmaro"
  }
}
